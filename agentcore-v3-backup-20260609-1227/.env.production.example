# AgentCore v3 — Production Environment Variables
# Copy to .env.production and fill in real values

# --- Database ---
DATABASE_URL=postgresql://agentcore:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/agentcore

# --- Security ---
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=REPLACE_WITH_ENCRYPTION_KEY

# --- AI / Suggy ---
SUGGY_PROJECT_KEY=sk-suggy-REPLACE_WITH_YOUR_PROJECT_KEY
SUGGY_BASE_URL=https://api.suggy.lol/v1
SUGGY_ACCOUNT_ID=default

# --- Payments / YooKassa ---
YOOKASSA_SHOP_ID=REPLACE_WITH_SHOP_ID
YOOKASSA_SECRET_KEY=REPLACE_WITH_SECRET_KEY
YOOKASSA_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# --- URLs ---
CLIENT_URL=https://agentcore.work
API_URL=https://api.agentcore.work
CORS_ORIGINS=https://agentcore.work,https://www.agentcore.work
WEBCHAT_API_KEY=REPLACE_WITH_WIDGET_API_KEY

# --- General ---
NODE_ENV=production
PORT=4000
MODEL_CACHE_TTL=60000

# --- Email ---
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@agentcore.work

# --- Telegra.ph ---
TELEGRAPH_ACCESS_TOKEN=

# --- Telegram ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Agent Pricing ---
AGENT_ACTIVATION_PRICE=4499
AGENT_MONTHLY_PRICE=2499
AGENT_FREE_CREDITS=1000

# --- Trial defaults ---
TRIAL_CREDIT_AMOUNT=10
TRIAL_DAYS=7
CREATE_DEFAULT_AGENTS=true

# --- Credit amounts per plan ---
PRO_CREDIT_AMOUNT=100
BUSINESS_CREDIT_AMOUNT=500

# --- Web (Frontend) ---
NEXT_PUBLIC_API_URL=https://api.agentcore.work
