# AgentCore API — Environment Variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentcore

# JWT
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=7d

# AI Provider (Suggy)
SUGGY_PROJECT_KEY=sk_proj_your_project_key_here
SUGGY_BASE_URL=https://api.suggy.lol/v1
SUGGY_ACCOUNT_ID=
MODEL_CACHE_TTL=60000

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Client
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:4000

# Webchat
WEBCHAT_API_KEY=generate-a-webchat-api-key-here

# Payments (YooKassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@agentcore.work

# Telegraph
TELEGRAPH_ACCESS_TOKEN=

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Agent Pricing
AGENT_ACTIVATION_PRICE=4499
AGENT_MONTHLY_PRICE=2499
AGENT_FREE_CREDITS=1000

# Trial
TRIAL_CREDIT_AMOUNT=10
TRIAL_DAYS=7

# Encryption
ENCRYPTION_KEY=change-me-to-a-32-char-secret!!
