FROM node:20-alpine AS base
WORKDIR /app

COPY apps/api/package.json apps/api/package-lock.json ./
RUN npm ci

COPY apps/api/ .
COPY packages/prisma/ packages/prisma/
RUN npx prisma generate
RUN npm prune --production

FROM node:20-alpine AS runner
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

COPY --from=base /app/package.json ./package.json
COPY --from=base /app/server.js ./server.js
COPY --from=base /app/config ./config
COPY --from=base /app/routes ./routes
COPY --from=base /app/services ./services
COPY --from=base /app/middleware ./middleware
COPY --from=base /app/utils ./utils
COPY --from=base /app/prisma-client.js ./prisma-client.js
COPY --from=base /app/node_modules ./node_modules

ENV NODE_ENV=production
ENV PORT=4000

EXPOSE 4000

USER nodejs

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --spider -q http://localhost:4000/api/health || exit 1

CMD ["node", "server.js"]
