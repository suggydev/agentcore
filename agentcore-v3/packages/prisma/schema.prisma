generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  plan                String               @default("TRIAL")
  trialEndsAt         DateTime?
  subscriptionActive  Boolean              @default(false)
  subscriptionStartsAt DateTime?
  /// @deprecated Field not yet used — reserved for future subscription lifecycle.
  subscriptionEndsAt   DateTime?
  settings            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  agents              Agent[]
  conversations       Conversation[]
  crmContacts         CRMContact[]
  knowledgeDocs       KnowledgeDocument[]
  billingTransactions BillingTransaction[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  /// RBAC not yet implemented — role always "OWNER".
  role         String    @default("OWNER")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
}

model Agent {
  id            String    @id @default(cuid())
  name          String
  description   String?
  model         String    @default("accounts/fireworks/models/glm-5p1")
  systemPrompt  String    @default("You are a helpful AI assistant.")
  temperature   Float     @default(0.7)
  maxTokens     Int       @default(2000)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  conversations Conversation[]

  @@index([workspaceId])
}

model Conversation {
  id          String    @id @default(cuid())
  title       String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  /// @deprecated Dead column — never populated or read.
  userId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]

  @@index([workspaceId])
  @@index([workspaceId, updatedAt])
  @@index([agentId])
}

model Message {
  id              String       @id @default(cuid())
  content         String
  role            String
  model           String?
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, order])
  @@index([createdAt])
}

model CRMContact {
  id          String    @id @default(cuid())
  name        String
  email       String?
  phone       String?
  status      String    @default("lead")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([email])
}

model KnowledgeDocument {
  id          String    @id @default(cuid())
  title       String
  content     String
  /// Valid types: "text", "url", "file". Currently only "text" is used.
  type        String    @default("text")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model BillingTransaction {
  id                 String    @id @default(cuid())
  /// Valid values: "subscription", "topup", "refund".
  type               String
  amount             Float
  description        String?
  /// Valid values: "pending", "completed", "failed".
  status             String    @default("completed")
  providerPaymentId  String?
  createdAt          DateTime  @default(now())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([type])
  @@index([status])
}
