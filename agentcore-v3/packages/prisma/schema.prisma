generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  TRIAL
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum UserRole {
  OWNER
  SUPERADMIN
  ADMIN
  USER
}

enum ContactStatus {
  lead
  contact
  customer
  archived
}

enum KnowledgeDocType {
  text
  url
  file
}

enum BillingType {
  subscription
  topup
  refund
}

enum BillingStatus {
  pending
  completed
  failed
}

model Workspace {
  id                  String    @id @default(cuid())
  name                String
  plan                Plan      @default(TRIAL)
  trialEndsAt         DateTime?
  subscriptionActive  Boolean   @default(false)
  subscriptionStartsAt DateTime?
  settings            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  users               User[]
  agents              Agent[]
  conversations       Conversation[]
  crmContacts         CRMContact[]
  knowledgeDocs       KnowledgeDocument[]
  billingTransactions BillingTransaction[]
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(OWNER)
  tokenVersion  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model Agent {
  id            String    @id @default(cuid())
  name          String
  description   String?
  model         String    @default("accounts/fireworks/models/glm-5p1")
  systemPrompt  String    @default("You are a helpful AI assistant.")
  temperature   Float     @default(0.7)
  maxTokens     Int       @default(2000)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  conversations Conversation[]
  integrations  Integration[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model Conversation {
  id          String    @id @default(cuid())
  title       String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]

  @@index([workspaceId])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, title])
  @@index([agentId])
}

model Message {
  id              String       @id @default(cuid())
  content         String
  role            String
  model           String?
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, order])
  @@index([conversationId, role])
  @@index([createdAt])
}

model CRMContact {
  id          String        @id @default(cuid())
  name        String
  email       String?
  phone       String?
  status      ContactStatus @default(lead)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([status])
}

model Integration {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider        String
  credentials     String
  status          String   @default("active")
  webhookUrl      String?
  webhookSecret   String?
  lastHealthCheck DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs IntegrationLog[]

  @@unique([agentId, provider])
  @@index([agentId])
  @@index([provider])
}

model IntegrationLog {
  id             String   @id @default(cuid())
  integrationId  String
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction      String
  eventType      String
  payload        String?
  status         String
  createdAt      DateTime @default(now())

  @@index([integrationId])
  @@index([integrationId, createdAt])
  @@index([direction])
}

model KnowledgeDocument {
  id          String            @id @default(cuid())
  title       String
  content     String
  type        KnowledgeDocType  @default(text)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model BillingTransaction {
  id                 String        @id @default(cuid())
  type               BillingType
  amount             Float
  description        String?
  status             BillingStatus @default(completed)
  providerPaymentId  String?
  createdAt          DateTime      @default(now())
  workspaceId        String
  workspace          Workspace     @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([type])
  @@index([status])
}
