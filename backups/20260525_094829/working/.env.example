# === PostgreSQL (Drizzle ORM) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/agentcore

# === JWT Secret (for local auth) ===
JWT_SECRET=

# === Supabase (optional — kept for migration period) ===
