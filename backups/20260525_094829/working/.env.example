# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_JWT_SECRET=

# === Frontend (VITE_*) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# === AI providers ===
