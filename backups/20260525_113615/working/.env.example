# ═══════════════════════════════════════════════════════════
# AgentCore Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/agentcore

# Connection pool settings
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=30000
DB_SLOW_QUERY_THRESHOLD_MS=100

# ── Authentication ──────────────────────────────────────────
# JWT secret — at least 32 characters (required in production)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Fallback: uses this key if JWT_SECRET is not set
AGENTCORE_ENCRYPTION_KEY=

# Admin panel password (min 8 characters)
ADMIN_PASSWORD=agentcore2026

# ── Logging ─────────────────────────────────────────────────
# One of: debug, info, warn, error, fatal
LOG_LEVEL=info

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── YooKassa (Billing) ─────────────────────────────────────
# Obtain from https://yookassa.ru/my
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOVABLE_AI_GATEWAY_KEY=

# ── Communication ──────────────────────────────────────────
# Resend (email)
RESEND_API_KEY=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Supabase (optional — for migration from Supabase Auth) ──
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
