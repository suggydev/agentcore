# ═══════════════════════════════════════════════════════════
# AgentCore Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────
NODE_ENV=development                    # development | staging | production
PORT=3000
HOST=0.0.0.0

# ── Database (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/agentcore

# Connection pool
DB_POOL_MAX=20                          # Max connections (1-100)
DB_POOL_IDLE_TIMEOUT_MS=30000           # Idle timeout in ms
DB_POOL_CONNECTION_TIMEOUT_MS=10000      # Connection timeout in ms
DB_QUERY_TIMEOUT_MS=30000               # Query timeout in ms
DB_SLOW_QUERY_THRESHOLD_MS=100          # Log queries slower than this

# ── Authentication ──────────────────────────────────────
# JWT secret — MUST be at least 32 characters in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Encryption key for sensitive data at rest
AGENTCORE_ENCRYPTION_KEY=change-me-16chars-min

# Admin password for /admin panel
ADMIN_PASSWORD=agentcore2026

# ── YooKassa (Billing) ─────────────────────────────────
# Obtain from https://yookassa.ru/my
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── AI Providers ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=

# ── Slack Integration ──────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ── Twilio (WhatsApp/SMS) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Lovable AI Gateway ─────────────────────────────────
LOVABLE_AI_GATEWAY_KEY=

# ── Supabase (optional — for migration compatibility) ──
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info                          # debug | info | warn | error | fatal

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000             # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
